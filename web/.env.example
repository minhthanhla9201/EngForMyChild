# Sao chép thành web/.env và chỉnh theo máy. KHÔNG commit .env thật.

# Bảo mật
SECRET_KEY=doi-thanh-chuoi-ngau-nhien-dai
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# CSDL — mặc định SQLite. Đổi sang MySQL chỉ bằng dòng dưới (không sửa code):
# DATABASE_URL=mysql://eng:engpass@db:3306/eng?charset=utf8mb4
DATABASE_URL=sqlite:///db.sqlite3

# Service ASR (faster-whisper) — dùng từ GĐ 3
ASR_URL=http://asr:9000

# Giọng TTS mặc định (edge-tts) — dùng từ GĐ 1
TTS_VOICE=en-US-AnaNeural

# Log — mức log & thư mục chứa file log (mặc định web/logs/)
LOG_LEVEL=INFO
# LOG_DIR=logs
